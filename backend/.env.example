DOMAIN=localhost
DATABASE_URL=sqlite+aiosqlite:///./lunart.db
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8000
SECRET_KEY=change-this-in-production
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Use local during development. Change to cloudinary when your account is configured.
UPLOAD_STORAGE=local
UPLOAD_DIR=uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=lunart

# Mock keeps checkout in development mode.
PAYMENT_PROVIDER=mock
MOCK_PAYMENT_BASE_URL=https://sandbox.mercadopago.com.br/checkout/v1/redirect
